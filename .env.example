# maimai DX B50 data source
MAIMAI_SOURCE=diving_fish
MAIMAI_USERNAME=
MAIMAI_QQ=

# Local Phase 1 cache
MAIMAI_LOCAL_CACHE_DIR=src/data/maimai
MAIMAI_UPDATE_SECRET=

# Full record research / Phase 5 candidates.
# Diving-Fish Import-Token can fetch the current user's complete score records.
# Lxns tokens/friend code can fetch historical trend/play records when permissions are enabled.
DIVING_FISH_IMPORT_TOKEN=
DIVING_FISH_DEVELOPER_TOKEN=
LXNS_DEVELOPER_TOKEN=
LXNS_USER_TOKEN=
LXNS_FRIEND_CODE=

# Phase 2+ only. Keep the service role key server-side only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# World Cup Live Dashboard
# Keep this key server-side. Do not expose it in frontend code.
FOOTBALL_API_KEY=
FOOTBALL_LEAGUE_ID=1
FOOTBALL_SEASON=2026

# Optional fallback. Used only server-side when API-Football cannot access 2026 schedule data.
OPENAI_API_KEY=
OPENAI_SCHEDULE_MODEL=gpt-5.5

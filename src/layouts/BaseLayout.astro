---
import "../styles/tokens.css";
import "../styles/base.css";
import siteText from "../content/siteText";

const {
  title = siteText.shared.defaults.title,
  description = siteText.shared.defaults.description,
  bodyClass = ""
} = Astro.props;

const metaDescription = typeof description === "string" ? description.trim() : "";
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {metaDescription ? <meta name="description" content={metaDescription} /> : null}
    <title>{title}</title>
    <script is:inline>
      try {
        const savedTheme = window.localStorage.getItem("starsail-theme");

        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.dataset.theme = savedTheme;
        }
      } catch {
        document.documentElement.dataset.theme = "dark";
      }
    </script>
  </head>
  <body class={bodyClass || undefined}>
    <slot />
  </body>
</html>

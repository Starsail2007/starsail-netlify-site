---
import CoverImage from "./CoverImage.astro";
import siteText from "../../content/siteText";
import { formatAchievement } from "../../lib/maimai/format";
import type { MaimaiB50Item } from "../../lib/maimai/types";

interface Props {
  nearRankUp: MaimaiB50Item[];
  borderItems: MaimaiB50Item[];
  practiceItems: MaimaiB50Item[];
}

const { nearRankUp, borderItems, practiceItems } = Astro.props;
const text = siteText.maimai.sections.suggestions;
const b50Text = siteText.maimai.b50;
const groups = [
  [text.groups.nearRankUp, nearRankUp],
  [text.groups.borderItems, borderItems],
  [text.groups.practiceItems, practiceItems]
] as const;
---

<section class="maimai-panel suggestion-panel" aria-labelledby="maimai-suggestion-title">
  <div class="section-heading">
    <div>
      <h2 id="maimai-suggestion-title">{text.title}</h2>
      <p>{text.subtitle}</p>
    </div>
  </div>
  <div class="suggestion-groups" data-maimai-suggestions>
    {groups.map(([title, items]) => (
      <div class="suggestion-group">
        <h3>{title}</h3>
        {items.length > 0 ? (
          <ol>
            {items.slice(0, 4).map((item) => (
              <li class="suggestion-item">
                <CoverImage src={item.coverUrl} alt={`${item.title} ${b50Text.coverAltSuffix}`} />
                <div class="suggestion-song-copy">
                  <span class="suggestion-title">{item.title}</span>
                  <span class="suggestion-meta">
                    <span>{item.type}</span>
                    <span>{item.difficulty}</span>
                    <span>{text.constantLabel} {item.ds.toFixed(1)}</span>
                  </span>
                </div>
                <strong>{formatAchievement(item.achievements)}</strong>
              </li>
            ))}
          </ol>
        ) : (
          <p class="empty-note">{text.empty}</p>
        )}
      </div>
    ))}
  </div>
</section>

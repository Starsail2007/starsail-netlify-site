---
import StatusBadge from "./StatusBadge.astro";
import siteText from "../../content/siteText";
import { formatDateTime, formatRating, formatSource } from "../../lib/maimai/format";
import type { MaimaiSnapshot } from "../../lib/maimai/types";

interface Props {
  snapshot: MaimaiSnapshot;
}

const { snapshot } = Astro.props;
const text = siteText.maimai.hero;
---

<section class="maimai-hero maimai-panel">
  <div class="hero-copy">
    <p class="maimai-eyebrow">{text.eyebrow}</p>
    <h1>{text.title}</h1>
    <p>{text.description}</p>
  </div>

  <div class="player-card">
    <div>
      <span class="player-label">{text.playerLabel}</span>
      <strong data-maimai-field="nickname">{snapshot.nickname}</strong>
    </div>
    <div class="rating-display">
      <span>{text.ratingLabel}</span>
      <strong data-maimai-field="rating">{formatRating(snapshot.rating)}</strong>
    </div>
    <div class="hero-stats">
      <StatusBadge label={text.stats.b35} value={formatRating(snapshot.b35Rating)} />
      <StatusBadge label={text.stats.b15} value={formatRating(snapshot.b15Rating)} />
      <StatusBadge label={text.stats.source} value={formatSource(snapshot.source)} />
      <StatusBadge label={text.stats.updated} value={formatDateTime(snapshot.createdAt)} />
    </div>
  </div>
</section>

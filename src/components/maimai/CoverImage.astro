---
import { DEFAULT_COVER_URL } from "../../lib/maimai/covers";
import { withBasePath } from "../../lib/basePath";

const {
  src = DEFAULT_COVER_URL,
  alt = ""
} = Astro.props;
const fallbackSrc = withBasePath(DEFAULT_COVER_URL);
const imageSrc = withBasePath(src);
---

<img
  class="maimai-cover"
  src={imageSrc}
  alt={alt}
  loading="lazy"
  decoding="async"
  data-cover-fallback={fallbackSrc}
/>

---
import B50Grid from "./B50Grid.astro";
import PlayerHero from "./PlayerHero.astro";
import RatingTrend from "./RatingTrend.astro";
import SuggestionPanel from "./SuggestionPanel.astro";
import UpdateTimeline from "./UpdateTimeline.astro";
import siteText from "../../content/siteText";
import { getBorderItems, getHighValuePracticeItems, getNearRankUpItems } from "../../lib/maimai/suggestions";
import type { MaimaiRatingPoint, MaimaiSnapshot } from "../../lib/maimai/types";

interface Props {
  snapshot: MaimaiSnapshot;
  history: MaimaiRatingPoint[];
  remoteRefresh?: boolean;
}

const { snapshot, history, remoteRefresh = false } = Astro.props;
const nearRankUp = getNearRankUpItems(snapshot);
const borderItems = getBorderItems(snapshot);
const practiceItems = getHighValuePracticeItems(snapshot);
const text = siteText.maimai;
---

<div class="maimai-dashboard" data-maimai-dashboard data-maimai-remote-refresh={remoteRefresh ? "true" : "false"}>
  <PlayerHero snapshot={snapshot} />

  <div class="maimai-main-grid">
    <RatingTrend points={history} />
    <UpdateTimeline points={history} />
  </div>

  <B50Grid title={text.sections.b35.title} subtitle={text.sections.b35.subtitle} items={snapshot.b35} target="b35" />
  <B50Grid title={text.sections.b15.title} subtitle={text.sections.b15.subtitle} items={snapshot.b15} target="b15" />
  <SuggestionPanel nearRankUp={nearRankUp} borderItems={borderItems} practiceItems={practiceItems} />
</div>

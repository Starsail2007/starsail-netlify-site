---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="site-header">
  <div class="brand">
    <span class="mark">星帆 Starsail</span>
    <span>Personal test space</span>
  </div>
  <div class="header-actions">
    <ThemeToggle />
    <div class="builder" aria-label="网站搭建者">
      <a
        class="avatar-link"
        href="#avatar-modal"
        aria-label="放大查看星帆Starsail 的头像"
        aria-controls="avatar-modal"
      >
        <img src="/assets/avatar.jpeg" alt="星帆Starsail 的头像" />
      </a>
      <div class="credit">
        <span>Designed by</span>
        <strong>星帆Starsail</strong>
      </div>
    </div>
  </div>
</header>

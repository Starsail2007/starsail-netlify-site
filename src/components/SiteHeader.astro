---
import ThemeToggle from "./ThemeToggle.astro";
import siteText from "../content/siteText";

const text = siteText.home.header;
---

<header class="site-header">
  <div class="brand">
    <span class="mark">{text.brandName}</span>
    <span>{text.brandSubtitle}</span>
  </div>
  <div class="header-actions">
    <ThemeToggle />
    <div class="builder" aria-label={text.builderAriaLabel}>
      <a
        class="avatar-link"
        href="#avatar-modal"
        aria-label={text.avatarOpenAriaLabel}
        aria-controls="avatar-modal"
      >
        <img src="/assets/avatar.jpeg" alt={text.avatarAlt} />
      </a>
      <div class="credit">
        <span>{text.creditLabel}</span>
        <strong>{text.creditName}</strong>
      </div>
    </div>
  </div>
</header>

---
import ThemeToggle from "../ThemeToggle.astro";
import { withBasePath } from "../../lib/basePath";

const { text } = Astro.props;
const headlineChars = [...text.hero.headline];
const modalId = "entry-original-avatar-modal";
const avatarSrc = withBasePath("/assets/avatar.jpeg");
const derakkumaHeadSrc = withBasePath("/assets/maimai/derakkuma-head-closeup.png");
const footballSrc = withBasePath("/assets/worldcup/soccerball-shade.svg");
const contactText = text.avatarModal.contact;
const qqQrSrc = withBasePath(contactText.qq.qrSrc);
const gmailHref = `mailto:${contactText.gmail.address}`;
---

<section class="original-stage" aria-label={text.stageAriaLabel} data-interactive-root>
  <header class="original-header">
    <div class="original-version-label">{text.header.versionLabel}</div>
    <div class="original-header-actions">
      <ThemeToggle />
      <div class="original-builder" aria-label={text.header.builderAriaLabel}>
        <button
          class="original-avatar-link"
          type="button"
          aria-label={text.header.avatarOpenAriaLabel}
          data-entry-avatar-open={modalId}
        >
          <img src={avatarSrc} alt={text.header.avatarAlt} />
        </button>
        <div class="original-credit">
          <span>{text.header.creditLabel}</span>
          <strong>{text.header.creditName}</strong>
        </div>
      </div>
    </div>
  </header>

  <main class="original-main">
    <div class="original-hero">
      <h1 class="original-headline" aria-label={text.hero.headline}>
        {headlineChars.map((char, index) => (
          <span style={`--char-index: ${index};`}>{char}</span>
        ))}
      </h1>
      <p class="original-subcopy">
        {text.hero.subcopy.beforeStrong}{text.hero.subcopy.strong}{text.hero.subcopy.afterStrong}
      </p>
    </div>

    <nav class="original-option-rail" aria-label={text.options.ariaLabel}>
      {text.options.items.map((item, index) => {
        const isMaimaiOption = item.href === "/maimai/";
        const optionClass = [
          "original-option",
          isMaimaiOption ? "original-option-maimai" : "",
          item.featured ? "original-option-featured" : ""
        ].filter(Boolean).join(" ");

        return (
          <a
            class={optionClass}
            href={withBasePath(item.href)}
            style={`--option-index: ${index};`}
            aria-disabled={item.href === "#" ? "true" : undefined}
            data-entry-disabled={item.href === "#" ? "true" : undefined}
            data-option-prompt={item.prompt || undefined}
          >
            {isMaimaiOption && (
              <>
                <span class="original-option-maimai-light" aria-hidden="true"></span>
                <img
                  class="original-option-derakkuma"
                  src={derakkumaHeadSrc}
                  alt=""
                  loading="eager"
                  decoding="async"
                  aria-hidden="true"
                />
                <span class="original-option-maimai-glass" aria-hidden="true"></span>
              </>
            )}
            {item.featured && (
              <img
                class="original-option-football"
                src={footballSrc}
                alt=""
                loading="eager"
                decoding="async"
                aria-hidden="true"
              />
            )}
            <strong>{item.label || item.name}</strong>
          </a>
        );
      })}
    </nav>
  </main>

  <footer class="original-footer">
    <div>{text.footer.hint}</div>
    <div class="original-corner-actions" aria-label={text.announcement.ariaLabel}>
      <div class="original-announcement" role="status">
        <span class="original-announcement-dot" aria-hidden="true"></span>
        <span>{text.announcement.message}</span>
      </div>
      <button
        class="original-changelog-button"
        type="button"
        aria-label={text.changelog.ariaLabel}
        data-original-changelog-open
      >
        {text.changelog.label}
      </button>
    </div>
  </footer>
</section>

<div
  class="original-avatar-modal"
  id={modalId}
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${modalId}-title`}
  hidden
  data-entry-avatar-modal
>
  <div class="original-modal-backdrop" data-entry-modal-close></div>
  <section class="original-avatar-card">
    <button
      class="entry-modal-close original-modal-close"
      type="button"
      aria-label={text.avatarModal.closeAriaLabel}
      data-entry-modal-close
    ></button>
    <div class="original-profile-shell">
      <div class="original-avatar-visual">
        <div class="original-orbit-field" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="original-avatar-large">
          <img src={avatarSrc} alt={text.avatarModal.avatarAlt} />
        </div>
      </div>
      <div class="original-profile-main">
        <div class="original-avatar-copy">
          <h2 id={`${modalId}-title`}>{text.avatarModal.title}</h2>
          <p class="original-avatar-motto">{text.avatarModal.motto}</p>
          <p>{text.avatarModal.description}</p>
        </div>
        <div class="original-contact-panel" aria-label={contactText.ariaLabel}>
          <article class="original-contact-card original-contact-card-qq">
            <div class="original-contact-copy">
              <span class="original-contact-label">{contactText.qq.label}</span>
              <strong class="original-contact-value">{contactText.qq.value}</strong>
              <div class="original-contact-actions">
                <button
                  class="original-contact-action"
                  type="button"
                  data-entry-copy={contactText.qq.value}
                  data-copy-label={contactText.qq.copyLabel}
                  data-copy-done={contactText.qq.copyDone}
                >
                  {contactText.qq.copyLabel}
                </button>
              </div>
            </div>
            <button
              class="original-contact-qr"
              type="button"
              aria-label={contactText.qq.qrAriaLabel}
              data-entry-qr-open
            >
              <img src={qqQrSrc} alt={contactText.qq.qrAlt} loading="lazy" />
            </button>
          </article>

          <article class="original-contact-card original-contact-card-mail">
            <div class="original-contact-copy">
              <span class="original-contact-label">{contactText.gmail.label}</span>
              <strong class="original-contact-value original-contact-email">{contactText.gmail.address}</strong>
              <div class="original-contact-actions">
                <a class="original-contact-action" href={gmailHref}>
                  {contactText.gmail.mailLabel}
                </a>
                <button
                  class="original-contact-action"
                  type="button"
                  data-entry-copy={contactText.gmail.address}
                  data-copy-label={contactText.gmail.copyLabel}
                  data-copy-done={contactText.gmail.copyDone}
                >
                  {contactText.gmail.copyLabel}
                </button>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>

    <div
      class="original-qr-zoom"
      role="dialog"
      aria-label={contactText.qq.zoomAriaLabel}
      hidden
      data-entry-qr-zoom
    >
      <div class="original-qr-zoom-backdrop" data-entry-qr-close></div>
      <section class="original-qr-zoom-card">
        <button
          class="entry-modal-close original-modal-close original-qr-zoom-close"
          type="button"
          aria-label={contactText.qq.zoomCloseAriaLabel}
          data-entry-qr-close
        ></button>
        <img class="original-qr-zoom-image" src={qqQrSrc} alt={contactText.qq.qrAlt} loading="lazy" />
        <a
          class="original-contact-action original-qr-download"
          href={qqQrSrc}
          download="starsail-qq-qrcode.jpg"
        >
          {contactText.qq.downloadLabel}
        </a>
      </section>
    </div>
  </section>
</div>

<div
  class="original-changelog-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="original-changelog-title"
  hidden
  data-original-changelog-modal
>
  <div class="original-modal-backdrop" data-original-changelog-close></div>
  <section class="original-changelog-card">
    <button
      class="entry-modal-close original-modal-close"
      type="button"
      aria-label={text.changelog.closeAriaLabel}
      data-original-changelog-close
    ></button>
    <div class="original-changelog-content">
      <h2 id="original-changelog-title">{text.changelog.title}</h2>
      <ol class="original-changelog-timeline">
        {text.changelog.items.map((item) => (
          <li>
            <time>
              <span>{item.date}</span>
              {item.version ? <> <span class="original-changelog-version">{item.version}</span></> : null}
            </time>
            <p>
              {item.parts.map((part) => (
                <span>{part.text}</span>
              ))}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>
</div>

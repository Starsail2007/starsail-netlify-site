---
import siteText from "../content/siteText";

const text = siteText.shared.theme;
---

<button
  class="theme-toggle"
  type="button"
  aria-label={text.darkAriaLabel}
  title={text.title}
>
  <span class="theme-glyph" aria-hidden="true"></span>
  <span class="theme-label">{text.initialLabel}</span>
</button>

---
import siteText from "../content/siteText";

const text = siteText.shared.theme;
---

<button
  class="theme-toggle"
  type="button"
  aria-label={text.darkAriaLabel}
  title={text.title}
  data-theme-dark-label={text.darkLabel}
  data-theme-light-label={text.lightLabel}
  data-theme-dark-aria-label={text.darkAriaLabel}
  data-theme-light-aria-label={text.lightAriaLabel}
>
  <span class="theme-glyph" aria-hidden="true"></span>
  <span class="theme-label">{text.initialLabel}</span>
</button>

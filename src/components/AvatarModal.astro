---
import siteText from "../content/siteText";
import { withBasePath } from "../lib/basePath";

const text = siteText.home.avatarModal;
const avatarSrc = withBasePath("/assets/avatar.jpeg");
---

<div
  class="avatar-modal"
  id="avatar-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="avatar-modal-title"
  hidden
>
  <button class="modal-close" type="button" aria-label={text.closeAriaLabel}>
    {text.closeButton}
  </button>
  <div class="avatar-card">
    <div class="avatar-large">
      <img src={avatarSrc} alt={text.avatarAlt} />
    </div>
    <div class="avatar-modal-copy">
      <h2 id="avatar-modal-title">{text.title}</h2>
      <p class="avatar-motto">{text.motto}</p>
      <p class="avatar-desc">{text.description}</p>
    </div>
  </div>
</div>

<div
  class="avatar-modal"
  id="avatar-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="avatar-modal-title"
  hidden
>
  <button class="modal-close" type="button" aria-label="关闭头像展示">x</button>
  <div class="avatar-card">
    <div class="avatar-large">
      <img src="/assets/avatar.jpeg" alt="星帆Starsail 的头像放大图" />
    </div>
    <div class="avatar-modal-copy">
      <h2 id="avatar-modal-title">星帆Starsail</h2>
      <p class="avatar-motto">天接云涛连晓雾，星河欲转千帆舞。</p>
      <p class="avatar-desc">该小窝由星帆Starsail筑成。</p>
    </div>
  </div>
</div>

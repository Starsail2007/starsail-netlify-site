---
import BaseLayout from "../layouts/BaseLayout.astro";
import siteText from "../content/siteText";
import "../styles/intro-loader.css";

const text = siteText.introDemo;
const variantEntries = Object.entries(text.variants);
const defaultVariant = variantEntries[0]?.[0] ?? "moonlit";
const defaultVariantText = text.variants[defaultVariant];
const introVariantsJson = JSON.stringify(text.variants).replaceAll("<", "\\u003c");
---

<BaseLayout
  title={text.meta.title}
  description={text.meta.description}
  bodyClass="intro-demo-page"
>
  <section class="intro-demo" aria-label={text.pageAriaLabel} data-intro-demo data-variant={defaultVariant}>
    <div class="intro-demo-shell">
      <header class="intro-demo-header">
        <div class="intro-demo-brand">
          <span class="intro-demo-mark">{text.brandLabel}</span>
          <span data-variant-title>{defaultVariantText.title}</span>
        </div>
        <svg class="intro-mini-mark" viewBox="0 0 44 44" aria-hidden="true">
          <circle cx="22" cy="22" r="18" />
          <path d="M13 25 C17 14 27 14 31 25 C27 30 17 30 13 25 Z" />
          <circle cx="14" cy="16" r="3.2" />
          <circle cx="20" cy="12" r="3.2" />
          <circle cx="26" cy="12" r="3.2" />
          <circle cx="32" cy="16" r="3.2" />
        </svg>
      </header>

      <main class="intro-demo-main">
        <p class="intro-demo-eyebrow">{text.eyebrow}</p>
        <h1>{text.title}</h1>
        <p class="intro-demo-subtitle">{text.subtitle}</p>
        <nav class="intro-variant-picker" aria-label={text.variantPickerAriaLabel}>
          {variantEntries.map(([key, variant], index) => (
            <button type="button" data-variant-choice={key} aria-pressed={String(index === 0)}>
              <span>{variant.shortcut}</span>
              <span>{variant.buttonLabel}</span>
            </button>
          ))}
        </nav>
      </main>

      <footer class="intro-demo-footer">
        <span data-variant-note>{defaultVariantText.note}</span>
        <button class="intro-replay" type="button" data-replay-intro>{text.replayButton}</button>
      </footer>
    </div>

    <div class="intro-loader is-playing" aria-hidden="true" data-intro-loader>
      <div class="intro-field" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="intro-variant intro-sigil intro-sigil-moonlit" data-variant-panel="moonlit">
        <svg class="intro-art sigil-art" viewBox="0 0 260 260" role="img" aria-label={text.variants.moonlit.artAriaLabel}>

  <script type="application/json" id="intro-variant-text" set:html={introVariantsJson} />
  <script is:inline>
  const root = document.querySelector("[data-intro-demo]");
  const loader = document.querySelector("[data-intro-loader]");
  const replayButton = document.querySelector("[data-replay-intro]");
  const variantButtons = [...document.querySelectorAll("[data-variant-choice]")];
  const variantPanels = [...document.querySelectorAll("[data-variant-panel]")];
  const variantTitle = document.querySelector("[data-variant-title]");
  const variantNote = document.querySelector("[data-variant-note]");
  const variantText = document.querySelector("#intro-variant-text");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const variants = JSON.parse(variantText?.textContent || "{}");
  let finishTimer;
  let hideTimer;

  const parseDuration = (value) => {
    const trimmed = value.trim();

    if (!trimmed) {
      return 1700;
    }

    if (trimmed.endsWith("ms")) {
      return Number.parseFloat(trimmed);
    }

    if (trimmed.endsWith("s")) {
      return Number.parseFloat(trimmed) * 1000;
    }

    return Number.parseFloat(trimmed) || 1700;
  };

  const getIntroDuration = () => {
    if (!root) {
      return 1700;
    }

    const styles = window.getComputedStyle(root);
    return parseDuration(styles.getPropertyValue("--intro-duration"));
  };

  const setVariant = (variant) => {
    if (!root || !variants[variant]) {
      return;
    }

    root.dataset.variant = variant;

    if (variantTitle) {
      variantTitle.textContent = variants[variant].title;
    }

    if (variantNote) {
      variantNote.textContent = variants[variant].note;
    }

    variantButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.variantChoice === variant));
    });

    variantPanels.forEach((panel) => {
      panel.hidden = panel.dataset.variantPanel !== variant;
    });
  };

  const finishIntro = () => {
    root?.classList.add("is-revealed");
    loader?.classList.add("is-finished");
    hideTimer = window.setTimeout(() => {
      if (loader) {
        loader.hidden = true;
      }
    }, reducedMotion.matches ? 40 : 260);
  };

  const playIntro = () => {
    if (!root || !loader) {
      return;
    }

    window.clearTimeout(finishTimer);
    window.clearTimeout(hideTimer);

    loader.hidden = false;
    root.classList.remove("is-revealed");
    loader.classList.remove("is-playing", "is-finished");
    void loader.offsetWidth;
    loader.classList.add("is-playing");

    finishTimer = window.setTimeout(
      finishIntro,
      reducedMotion.matches ? 120 : getIntroDuration()
    );
  };

  variantButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setVariant(button.dataset.variantChoice);
      playIntro();
    });
  });

  replayButton?.addEventListener("click", playIntro);
  window.requestAnimationFrame(playIntro);
  </script>

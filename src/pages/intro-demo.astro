---
import BaseLayout from "../layouts/BaseLayout.astro";
import siteText from "../content/siteText";
import "../styles/intro-loader.css";

const text = siteText.introDemo;
const variant = text.variants.b1SailPaw;
---

<BaseLayout
  title={text.meta.title}
  description={text.meta.description}
  bodyClass="intro-demo-page"
>
  <section class="intro-demo" aria-label={text.pageAriaLabel} data-intro-demo>
    <div class="intro-demo-shell">
      <header class="intro-demo-header">
        <div class="intro-demo-brand">
          <span class="intro-demo-mark">{text.brandLabel}</span>
          <span>{variant.title}</span>
        </div>
        <svg class="intro-mini-mark" viewBox="0 0 44 44" aria-hidden="true">
          <circle cx="22" cy="22" r="18" />
          <path d="M12.5 25.5 C16.7 14.8 27.3 14.8 31.5 25.5 C27.5 30.3 16.5 30.3 12.5 25.5 Z" />
          <circle cx="14" cy="16" r="3" />
          <circle cx="20" cy="12" r="3.1" />
          <circle cx="26" cy="12" r="3.1" />
          <circle cx="32" cy="16" r="3" />
        </svg>
      </header>

      <main class="intro-demo-main">
        <p class="intro-demo-eyebrow">{text.eyebrow}</p>
        <h1>{text.title}</h1>
        <p class="intro-demo-subtitle">{text.subtitle}</p>
        <div class="intro-demo-focus" aria-label={variant.title}>
          <span>{variant.shortcut}</span>
          <span>{variant.buttonLabel}</span>
        </div>
      </main>

      <footer class="intro-demo-footer">
        <span>{variant.note}</span>
        <button class="intro-replay" type="button" data-replay-intro>{text.replayButton}</button>
      </footer>
    </div>

    <div class="intro-loader is-playing" aria-hidden="true" data-intro-loader>
      <div class="intro-field" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="intro-sigil" aria-hidden="true">
        <svg class="intro-art b1-art" viewBox="0 0 280 260" role="img" aria-label={variant.artAriaLabel}>
          <path class="b1-orbit b1-draw" d="M48 158 C88 101 162 58 230 82" />
          <path class="b1-orbit-echo b1-draw" d="M61 173 C104 128 171 98 224 112" />
          <line class="b1-mast b1-draw" x1="132" y1="44" x2="132" y2="205" />
          <path class="b1-sail b1-sail-main" d="M143 52 L216 168 L143 146 Z" />
          <path class="b1-sail b1-sail-soft" d="M121 73 L75 176 L121 153 Z" />
          <path class="b1-hull b1-draw" d="M77 189 C111 207 168 210 211 189" />
          <path class="b1-hull-glow b1-draw" d="M97 199 C126 209 166 209 195 198" />
          <g class="b1-paw">
            <ellipse class="b1-pad" cx="119" cy="159" rx="5" ry="8" />
            <ellipse class="b1-pad" cx="132" cy="151" rx="5" ry="9" />
            <ellipse class="b1-pad" cx="146" cy="151" rx="5" ry="9" />
            <ellipse class="b1-pad" cx="159" cy="159" rx="5" ry="8" />
            <path class="b1-pad b1-pad-main" d="M139 166 C150 166 159 175 160 186 C161 196 151 202 141 198 C139 197 138 197 136 198 C126 202 116 196 117 186 C118 175 128 166 139 166 Z" />
          </g>
          <path class="b1-star" d="M221 56 L226 68 L239 72 L227 78 L221 91 L216 78 L203 72 L216 68 Z" />
        </svg>
      </div>
    </div>
  </section>

  <script is:inline>
    const root = document.querySelector("[data-intro-demo]");
    const loader = document.querySelector("[data-intro-loader]");
    const replayButton = document.querySelector("[data-replay-intro]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let finishTimer;
    let hideTimer;

    const parseDuration = (value) => {
      const trimmed = value.trim();

      if (!trimmed) {
        return 1280;
      }

      if (trimmed.endsWith("ms")) {
        return Number.parseFloat(trimmed);
      }

      if (trimmed.endsWith("s")) {
        return Number.parseFloat(trimmed) * 1000;
      }

      return Number.parseFloat(trimmed) || 1280;
    };

    const getIntroDuration = () => {
      if (!root) {
        return 1280;
      }

      return parseDuration(window.getComputedStyle(root).getPropertyValue("--intro-duration"));
    };

    const finishIntro = () => {
      root?.classList.add("is-revealed");
      loader?.classList.add("is-finished");
      hideTimer = window.setTimeout(() => {
        if (loader) {
          loader.hidden = true;
        }
      }, reducedMotion.matches ? 40 : 320);
    };

    const playIntro = () => {
      if (!root || !loader) {
        return;
      }

      window.clearTimeout(finishTimer);
      window.clearTimeout(hideTimer);

      loader.hidden = false;
      root.classList.remove("is-revealed");
      loader.classList.remove("is-playing", "is-finished");
      void loader.offsetWidth;
      loader.classList.add("is-playing");

      finishTimer = window.setTimeout(
        finishIntro,
        reducedMotion.matches ? 120 : getIntroDuration()
      );
    };

    replayButton?.addEventListener("click", playIntro);
    window.requestAnimationFrame(playIntro);
  </script>
</BaseLayout>

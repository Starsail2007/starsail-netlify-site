          <path class="sigil-draw stroke-ink" style="--d: 360ms; --dash: 420;" d="M59 168 C82 193 131 202 174 188 C187 184 198 178 207 169" />
          <path class="sigil-draw stroke-blue soft-line" style="--d: 470ms; --dash: 210;" d="M70 178 C98 187 153 188 190 174" />

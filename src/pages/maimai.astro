---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import MaimaiDashboard from "../components/maimai/MaimaiDashboard.astro";
import siteText from "../content/siteText";
import { withBasePath } from "../lib/basePath";
import latestSnapshot from "../data/maimai/latest.snapshot.json";
import historySnapshots from "../data/maimai/history.snapshots.json";
import "../styles/maimai.css";

const history = historySnapshots.map((snapshot) => ({
  createdAt: snapshot.createdAt,
  rating: snapshot.rating,
  b35Rating: snapshot.b35Rating,
  b15Rating: snapshot.b15Rating
}));
const initialDataJson = JSON.stringify({ snapshot: latestSnapshot, history }).replaceAll("<", "\\u003c");
const remoteRefresh = import.meta.env.PUBLIC_MAIMAI_REMOTE_REFRESH === "true";
const text = siteText.maimai;
const homeHref = withBasePath("/");
---

<BaseLayout
  title={text.meta.title}
  description={text.meta.description}
  bodyClass="maimai-body"
>
  <div class="maimai-page">
    <header class="maimai-topbar" aria-label={text.pageToolsAriaLabel}>
      <a class="maimai-home-button" href={homeHref} aria-label={text.topbar.homeAriaLabel}>
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M3 10.8 12 3l9 7.8" />
          <path d="M5.5 9.4V21h13V9.4" />
          <path d="M9.5 21v-6h5v6" />
        </svg>
      </a>
      <ThemeToggle />
    </header>
    <MaimaiDashboard snapshot={latestSnapshot} history={history} remoteRefresh={remoteRefresh} />
    <div class="maimai-empty-state" data-maimai-empty hidden>
      <strong>{text.emptyState.title}</strong>
      <span>{text.emptyState.description}</span>
    </div>
  </div>

  <script type="application/json" id="maimai-initial-data" set:html={initialDataJson} />
  <script>
    import "../scripts/theme.js";
    import "../scripts/maimai-dashboard.js";
  </script>
</BaseLayout>

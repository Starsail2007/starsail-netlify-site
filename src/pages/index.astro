---
import BaseLayout from "../layouts/BaseLayout.astro";
import AvatarModal from "../components/AvatarModal.astro";
import MotionHeadline from "../components/MotionHeadline.astro";
import SiteHeader from "../components/SiteHeader.astro";
import siteText from "../content/siteText";
import "../styles/home.css";

const text = siteText.home;
---

<BaseLayout
  title={text.meta.title}
  description={text.meta.description}
>
  <section class="stage" aria-label={text.stageAriaLabel} data-interactive-root>
    <SiteHeader />

    <main>
      <div class="eyebrow">{text.hero.eyebrow}</div>
      <MotionHeadline text={text.hero.headline} />
      <p class="subcopy">
        {text.hero.subcopy.beforeStrong}<strong>{text.hero.subcopy.strong}</strong>{text.hero.subcopy.afterStrong}
      </p>
      <div class="actions">
        <div class="status" aria-live="polite">{text.hero.status}</div>
        <a class="project-link" href="/worldcup/">{text.hero.worldcupLink}</a>
        <nav class="controls" aria-label={text.hero.motionAriaLabel}>
          {text.hero.motionModes.map((mode, index) => (
            <button type="button" data-mode={mode.key} aria-pressed={String(index === 0)}>
              {mode.label}
            </button>
          ))}
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <div class="hint">{text.footer.hint}</div>
      <div class="footer-note">{text.footer.techNote}</div>
    </footer>
  </section>

  <AvatarModal />
</BaseLayout>

<script>
  import "../scripts/theme.js";
  import "../scripts/motion.js";
  import "../scripts/avatar-modal.js";
</script>

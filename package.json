{
  "name": "starsail-netlify-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "pnpm text:check && astro build",
    "deploy:check": "pnpm build",
    "text:check": "node scripts/check-site-text.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "maimai:update": "tsx scripts/maimai/cli.ts update",
    "maimai:status": "tsx scripts/maimai/cli.ts status",
    "maimai:history": "tsx scripts/maimai/cli.ts history",
    "maimai:music-cache": "tsx scripts/maimai/cli.ts music-cache",
    "maimai:export": "tsx scripts/maimai/cli.ts export",
    "maimai:records-probe": "tsx scripts/maimai/cli.ts records-probe",
    "maimai:records-save": "tsx scripts/maimai/cli.ts records-save",
    "maimai:lxns-probe": "tsx scripts/maimai/cli.ts lxns-probe",
    "maimai:trend-import": "tsx scripts/maimai/cli.ts trend-import"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.7.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.109.0",
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
